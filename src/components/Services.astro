---
const services = [
  {
    icon: "⬡",
    title: "Sitios Web Premium",
    description: "Landing pages, sitios institucionales y e-commerce. Diseño único, código limpio, animaciones y 100% mobile-first.",
    tags: ["Astro", "React", "Tailwind CSS", "Vite"]
  },
  {
    icon: "◈",
    title: "Contenido Visual",
    description: "Diseño de piezas gráficas, banners, identidad visual y contenido para redes sociales con Canva Pro y herramientas pro.",
    tags: ["Canva Pro", "Branding", "Social Media", "Diseño Gráfico"]
  },
  {
    icon: "⊕",
    title: "Gestión de RRSS",
    description: "Estrategia, diseño y gestión mensual de redes sociales. Posts, Reels, Stories y calendario editorial con identidad de marca consistente.",
    tags: ["Instagram", "TikTok", "Reels", "Stories", "Copywriting", "Canva Pro"]
  }
];
---
<section id="services" class="py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14 reveal">
      <p class="font-mono-custom text-xs text-muted uppercase tracking-widest mb-3">// servicios</p>
      <h2 class="serif-display text-3xl md:text-5xl text-text font-normal">
        Lo que <em class="grad-text not-italic">construyo</em>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-px" style="background: linear-gradient(90deg, #2c045f, #1a1030);">
      {services.map((s) => (
        <div class="service-card p-8 bg-bg transition-all duration-300 cursor-default rounded-xl md:rounded-none border border-border md:border-0">
          <!-- Icon -->
          <div class="text-4xl mb-6 leading-none service-icon" style="color:#149af2; font-size:42px;">{s.icon}</div>
          <!-- Title -->
          <h3 class="serif-display text-xl font-normal text-text mb-3">{s.title}</h3>
          <!-- Description -->
          <p class="text-sm text-muted leading-relaxed mb-6">{s.description}</p>
          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {s.tags.map(tag => (
              <span class="font-mono-custom text-xs px-2 py-1 rounded"
                    style="background: rgba(44,4,95,0.4); color:#7060a0; border: 1px solid #1a1030;">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
