---
const items = [
  "Astro", "React Islands", "Tailwind CSS", "Vite", "Vercel",
  "Canva Pro", "Gestión de RRSS", "JavaScript", "CSS Animations", "Branding Digital"
];
---
<div class="relative w-full overflow-hidden py-4" style="border-top: 1px solid #1a1030; border-bottom: 1px solid #1a1030; background: #0a0612;">
  <div class="marquee-track">
    {[...items, ...items].map((item) => (
      <div class="flex items-center gap-4 px-4 flex-shrink-0">
        <span class="font-mono-custom text-xs uppercase tracking-widest whitespace-nowrap" style="color:#7060a0;">{item}</span>
        <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: linear-gradient(135deg, #5d038c, #149af2);"></span>
      </div>
    ))}
  </div>
</div>
