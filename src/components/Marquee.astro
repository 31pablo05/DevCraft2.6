---
const items = [
  "Astro", "React Islands", "Tailwind CSS", "Vite", "Vercel",
  "Canva Pro", "Gestión de RRSS", "JavaScript", "CSS Animations", "Branding Digital"
];
const doubled = [...items, ...items];
---
<div
  aria-hidden="true"
  class="relative w-full overflow-hidden py-4"
  style="border-top: 1px solid #1a1030; border-bottom: 1px solid #1a1030; background: #0a0612; mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%); -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);"
>
  <div class="marquee-track">
    {doubled.map((item, i) => (
      <div class="flex items-center gap-4 px-4 flex-shrink-0">
        {i % 2 === 0
          ? <span class="grad-text font-mono-custom text-xs uppercase tracking-widest whitespace-nowrap">{item}</span>
          : <span class="font-mono-custom text-xs uppercase tracking-widest whitespace-nowrap" style="color:#7060a0;">{item}</span>
        }
        <span class="serif-display flex-shrink-0" style="color:#3d1495; font-size:1rem; line-height:1;">·</span>
      </div>
    ))}
  </div>

  <!-- Fila 2: derecha (inversa) -->
  <div class="marquee-track marquee-reverse mt-2" style="opacity: 0.45;">
    {doubled.map((item, i) => (
      <div class="flex items-center gap-4 px-4 flex-shrink-0">
        {i % 2 !== 0
          ? <span class="font-mono-custom text-xs uppercase tracking-widest whitespace-nowrap" style="color:#5d038c;">{item}</span>
          : <span class="font-mono-custom text-xs uppercase tracking-widest whitespace-nowrap" style="color:#3d1495;">{item}</span>
        }
        <span class="serif-display flex-shrink-0" style="color:#2c045f; font-size:1rem; line-height:1;">✦</span>
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-reverse {
    animation: marquee 28s linear infinite reverse;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track, .marquee-reverse {
      animation: none;
      transform: none;
    }
  }
</style>
