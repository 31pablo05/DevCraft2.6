---
<section class="py-20 px-6 md:px-12" style="background: #0a0612;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-10 reveal">
      <p class="font-mono-custom text-xs text-muted uppercase tracking-widest mb-3">// stack tecnológico</p>
      <h2 class="serif-display text-3xl md:text-5xl text-text font-normal">
        Las <em class="grad-text not-italic">herramientas</em>
      </h2>
    </div>

    <!-- Separator -->
    <div class="mb-6 reveal" style="height: 1px; background: #1a1030;"></div>

    <!-- Grid -->
    <div class="grid grid-cols-4 md:grid-cols-8 gap-px reveal" style="background:#1a1030;">
      {stack.map(item => (
        <div
          class="stack-item group/item bg-surface p-6 flex flex-col items-center gap-3 cursor-default transition-all duration-300 hover:bg-[#0f0a1f]"
        >
          <div
            class="stack-icon-wrap transition-transform duration-300 group-hover/item:scale-110"
            style={`filter: drop-shadow(0 0 0px ${item.color});`}
            onmouseover={`this.style.filter='drop-shadow(0 0 8px ${item.color})'`}
            onmouseout={`this.style.filter='drop-shadow(0 0 0px ${item.color})'`}
            set:html={item.svgPath}
          />
          <span
            class="stack-item-name font-mono-custom text-xs text-muted transition-colors duration-300 group-hover/item:text-[#feffff]"
          >{item.name}</span>
        </div>
      ))}
    </div>

    <!-- Separador flujo de trabajo & IA -->
    <div class="mt-12 mb-6 reveal" style="height:1px; background:#1a1030; position:relative;">
      <span class="font-mono-custom text-xs text-muted uppercase tracking-widest"
            style="position:absolute; top:-9px; left:0; background:#0a0612; padding-right:12px;">
        // flujo de trabajo & ia
      </span>
    </div>

    <!-- Grid workflow -->
    <div class="grid grid-cols-4 md:grid-cols-5 gap-px reveal" style="background:#1a1030;">
      {workflow.map(item => (
        <div class="stack-item group/item bg-surface p-6 flex flex-col items-center gap-3 cursor-default transition-all duration-300 hover:bg-[#0f0a1f]">
          <div
            class="stack-icon-wrap transition-transform duration-300 group-hover/item:scale-110"
            style={`filter: drop-shadow(0 0 0px ${item.color});`}
            onmouseover={`this.style.filter='drop-shadow(0 0 8px ${item.color})'`}
            onmouseout={`this.style.filter='drop-shadow(0 0 0px ${item.color})'`}
            set:html={item.svgPath}
          />
          <span class="stack-item-name font-mono-custom text-xs text-muted transition-colors duration-300 group-hover/item:text-[#feffff]">
            {item.name}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .stack-icon-wrap {
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .stack-item:hover .stack-icon-wrap {
    filter: drop-shadow(0 0 8px rgba(20,154,242,0.6)) brightness(1.2);
    transform: scale(1.1) translateY(-2px);
  }
  .stack-item:hover .stack-item-name {
    color: #feffff;
    transition: color 0.2s ease;
  }
</style>
