---
// Datos de los reels producidos para clientes
const reels = [
  {
    client: "Café Doncar",
    label: "Cliente · Gastronomía",
    description: "Reel de presentación para cuenta de Instagram de hamburguesería y pizzería artesanal.",
    instagramUrl: "#",
    videoSrc: "/reels/doncar.mp4",
    poster: "/reels/doncar-poster.webp"
  },
  {
    client: "Independiente",
    label: "Contenido propio · Freelance",
    description: "Reel educativo / demostrativo creado para mostrar capacidades de producción de contenido.",
    instagramUrl: "#",
    videoSrc: "/reels/independiente.mp4",
    poster: "/reels/independiente-poster.webp"
  },
  {
    client: "DevCraft",
    label: "Marca personal · Dev",
    description: "Reel para la cuenta de Instagram de DevCraft. Presentación de servicios web y diseño.",
    instagramUrl: "#",
    videoSrc: "/reels/devcraft.mp4",
    poster: "/reels/devcraft-poster.webp"
  }
];
---

<section id="reels" class="py-24 px-6 md:px-12" style="background: #0a0612;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14 reveal">
      <p class="font-mono-custom text-xs text-muted uppercase tracking-widest mb-3">// contenido visual</p>
      <h2 class="serif-display text-3xl md:text-5xl text-text font-normal">
        Reels que <em class="grad-text not-italic">produje</em>
      </h2>
    </div>

    <!-- Grid de reels -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reels.map((reel, i) => (
        <div
          class={`reel-card rounded-lg overflow-hidden transition-all duration-300 reveal reveal-delay-${i + 1}`}
          style="background: #0a0612; border: 1px solid #1a1030;"
        >
          <!-- Video en formato reel (9:16) -->
          <div style="aspect-ratio: 9/16; width: 100%; background: #000;">
            <video
              class="reel-video"
              src={reel.videoSrc}
              poster={reel.poster}
              muted
              loop
              playsinline
              preload="none"
              style="width: 100%; height: 100%; object-fit: cover; display: block;"
            />
          </div>

          <!-- Info de la card -->
          <div class="p-5 flex flex-col gap-3">
            <!-- Cliente -->
            <h3 class="serif-display text-lg font-normal" style="color: #fff;">{reel.client}</h3>
            <!-- Label -->
            <p class="font-mono-custom text-xs uppercase tracking-widest" style="color: #7060a0;">{reel.label}</p>
            <!-- Descripción -->
            <p class="text-sm text-muted leading-relaxed">{reel.description}</p>
            <!-- Botón Ver en Instagram -->
            <a
              href={reel.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="ig-link font-mono-custom text-xs px-3 py-2 rounded inline-flex items-center gap-2 w-fit transition-all duration-300"
              style="background: rgba(44,4,95,0.4); color: #7060a0; border: 1px solid #1a1030;"
            >
              <!-- Ícono de Instagram SVG inline -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
              Ver en Instagram →
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Glow azul suave al hacer hover en la card */
  .reel-card:hover {
    box-shadow: 0 0 20px rgba(20, 154, 242, 0.12);
  }

  /* Sutil cambio de color en el link al hover */
  .ig-link:hover {
    color: #149af2;
    border-color: #149af2;
  }
</style>

<script>
  // Pause/play del video al hacer hover sobre la card
  document.querySelectorAll<HTMLElement>('.reel-card').forEach((card) => {
    const video = card.querySelector<HTMLVideoElement>('.reel-video');
    if (!video) return;

    card.addEventListener('mouseenter', () => {
      video.play();
    });

    card.addEventListener('mouseleave', () => {
      video.pause();
    });
  });
</script>
