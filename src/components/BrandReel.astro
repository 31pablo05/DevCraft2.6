---
---
<section class="relative py-8 px-6 overflow-hidden" style="background: #000;">

  <!-- Ambient glows -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[160px] rounded-full"
         style="background: radial-gradient(ellipse, rgba(93,3,140,0.22) 0%, transparent 70%); filter: blur(60px);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[260px] h-[120px] rounded-full"
         style="background: radial-gradient(ellipse, rgba(20,154,242,0.12) 0%, transparent 70%); filter: blur(40px);"></div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center gap-5">

    <!-- Eyebrow -->
    <div class="flex items-center gap-3 reveal">
      <div class="h-px w-8" style="background: linear-gradient(90deg, transparent, #5d038c);"></div>
      <span class="font-mono-custom text-xs tracking-[0.2em] uppercase" style="color:#7060a0;">Identidad de marca</span>
      <div class="h-px w-8" style="background: linear-gradient(90deg, #149af2, transparent);"></div>
    </div>

    <!-- Video frame -->
    <div class="reveal w-full relative">
      <!-- Neon border -->
      <div class="absolute -inset-[2px] rounded-xl pointer-events-none" style="background: linear-gradient(135deg, #5d038c, #149af2, #5d038c); opacity: 0.75;"></div>
      <!-- Outer glow -->
      <div class="absolute -inset-[12px] rounded-2xl pointer-events-none"
           style="background: radial-gradient(ellipse at center, rgba(93,3,140,0.35) 0%, transparent 70%); filter: blur(18px);"></div>
      <div class="absolute -inset-[20px] rounded-2xl pointer-events-none"
           style="background: radial-gradient(ellipse at center, rgba(20,154,242,0.2) 0%, transparent 70%); filter: blur(28px);"></div>

      <!-- Fixed-height crop container -->
      <div class="relative rounded-xl overflow-hidden" style="height: 200px; background: #000;">
        <video
          id="brand-video"
          autoplay
          loop
          muted
          playsinline
          preload="none"
          style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;"
        >
          <source src="/videos/vid2.mp4" type="video/mp4" />
        </video>
        <!-- Inner vignette -->
        <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 40px rgba(0,0,0,0.5);"></div>
      </div>
    </div>

    <!-- Tagline -->
    <p class="reveal text-center font-mono-custom text-xs tracking-[0.15em] uppercase" style="color:#7060a0;">
      Diseño · Desarrollo · Resultados
    </p>

  </div>
</section>

<script>
  const brandVideo = document.getElementById('brand-video') as HTMLVideoElement | null;
  if (brandVideo) {
    let started = false;
    const obs = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        if (!started) {
          brandVideo.preload = 'metadata';
          brandVideo.load();
          started = true;
        } else {
          brandVideo.play();
          obs.disconnect();
        }
      }
    }, { threshold: 0.1 });
    obs.observe(brandVideo);
  }
</script>
