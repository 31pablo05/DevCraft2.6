---
const steps = [
  {
    num: "01",
    title: "Descubrimiento",
    description: "Escucho tu proyecto, entiendo tu negocio y defino objetivos claros antes de escribir una sola línea de código."
  },
  {
    num: "02",
    title: "Diseño",
    description: "Defino la estructura visual, la paleta, las tipografías y la experiencia de usuario adaptada a tu marca."
  },
  {
    num: "03",
    title: "Desarrollo",
    description: "Código limpio, semántico y optimizado. Cada animación, componente y pantalla construido con atención al detalle."
  },
  {
    num: "04",
    title: "Lanzamiento",
    description: "Deploy en Vercel, revisión final, ajustes post-lanzamiento y soporte para que todo funcione perfecto."
  }
];
---
<section id="process" class="py-24 px-6 md:px-12" style="background: #0a0612;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14 reveal">
      <p class="font-mono-custom text-xs text-muted uppercase tracking-widest mb-3">// cómo trabajo</p>
      <h2 class="serif-display text-3xl md:text-5xl text-text font-normal">
        El <em class="grad-text not-italic">proceso</em>
      </h2>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px reveal" style="background:#1a1030;">
      {steps.map(step => (
        <div class="process-step bg-surface p-8 group cursor-default transition-all duration-300">
          <!-- Number -->
          <p
            class="serif-display italic font-normal leading-none mb-4 select-none transition-all duration-300"
            style="font-size: 4rem; color: #1a1030;"
          >
            {step.num}
          </p>
          <!-- Title -->
          <h3 class="serif-display text-lg font-normal text-text mb-3 group-hover:grad-text transition-all">
            {step.title}
          </h3>
          <!-- Description -->
          <p class="text-sm text-muted leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .process-step:hover .serif-display.italic {
    background: linear-gradient(135deg, #5d038c, #3d1495, #149af2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
