---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;

const statusConfig: Record<string, { label: string; color: string; bg: string }> = {
  'Producción': { label: 'Producción', color: '#4ade80', bg: 'rgba(74,222,128,.1)' },
  'Desarrollo':  { label: 'Desarrollo',  color: '#149af2', bg: 'rgba(20,154,242,.1)' },
  'Demo':        { label: 'Demo',        color: '#a78bfa', bg: 'rgba(167,139,250,.1)' }
};
const s = statusConfig[project.status] ?? statusConfig['Demo'];

const categoryIcons: Record<string, string> = {
  ecommerce: '🛒', health: '⚕️', food: '🍕', portfolio: '🎨',
  tools: '🔧', beauty: '✨', educacion: '📚', coaching: '🌱',
  retail: '🚲', automotive: '🔩', otros: '🌿', default: '💻'
};
const icon = categoryIcons[project.category] ?? categoryIcons.default;

const hasDemoLink   = project.demo   && project.demo   !== '#' && project.demo   !== '';
const hasGithubLink = project.github && project.github !== '#' && project.github !== '';
---

<article class="pcard group rounded-xl flex flex-col bg-bg transition-all duration-300 border border-[#1a1030] hover:border-[#3d1495]">

  <!-- Visual area: video with poster or gradient placeholder -->
  {project.video ? (
    <div class="relative h-44 rounded-t-xl overflow-hidden">
      <!-- Poster image (always visible) -->
      <img
        src={project.poster ?? project.posterSrc}
        alt={project.title}
        class="card-poster w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        width="400"
        height="176"
      />
      <!-- Video preview (fades in on hover / tap) -->
      <video
        class="card-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
        src={project.video}
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
      />
      <!-- Play button visible only on touch devices -->
      <button
        class="card-play-btn absolute inset-0 flex items-center justify-center w-full h-full bg-transparent border-0 cursor-pointer md:hidden"
        aria-label={`Reproducir preview de ${project.title}`}
        style="z-index:3;"
      >
        <span class="card-play-icon flex items-center justify-center w-10 h-10 rounded-full transition-all duration-300"
              style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,0.2);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><polygon points="5,3 19,12 5,21"/></svg>
        </span>
      </button>
      <!-- Bottom scrim for number legibility -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(to top, rgba(10,0,25,0.6) 0%, transparent 55%);"
      />
      <span
        class="serif-display italic absolute bottom-2 right-3 select-none leading-none"
        style="color: rgba(255,255,255,0.15); font-size: 3.5rem;"
      >
        {String(project.id).padStart(2, '0')}
      </span>
      <!-- Status badge top-right -->
      <span
        class="absolute top-2 right-2 font-mono-custom text-xs px-2 py-0.5 rounded-full"
        style={`color: ${s.color}; background: ${s.bg};`}
      >
        {s.label}
      </span>
      <!-- Category icon top-left -->
      <span
        class="absolute top-2 left-2 font-mono-custom text-xs px-2 py-1 rounded-full"
        style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);"
        aria-hidden="true"
      >
        {icon}
      </span>
    </div>
  ) : project.posterSrc ? (
    <div class="relative h-44 rounded-t-xl overflow-hidden">
      <img
        src={project.posterSrc}
        alt={project.title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        width="400"
        height="176"
      />
      <!-- Overlay -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);"
      />
      <!-- Project number bottom-right -->
      <span
        class="serif-display italic absolute bottom-2 right-3 select-none leading-none pointer-events-none"
        style="color: rgba(255,255,255,0.15); font-size: 3.5rem;"
      >
        {String(project.id).padStart(2, '0')}
      </span>
      <!-- Status badge top-right -->
      <span
        class="absolute top-2 right-2 font-mono-custom text-xs px-2 py-0.5 rounded-full"
        style={`color: ${s.color}; background: ${s.bg};`}
      >
        {s.label}
      </span>
      <!-- Category icon top-left -->
      <span
        class="absolute top-2 left-2 font-mono-custom text-xs px-2 py-1 rounded-full"
        style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);"
        aria-hidden="true"
      >
        {icon}
      </span>
    </div>
  ) : (
    <div
      class="relative h-44 rounded-t-xl flex items-center justify-center overflow-hidden"
      style="background: linear-gradient(135deg, #2c045f 0%, #3d1495 50%, rgba(20,154,242,0.12) 100%);"
    >
      <span class="text-5xl" aria-hidden="true">{icon}</span>
      <!-- Project number -->
      <span
        class="serif-display italic absolute bottom-2 right-3 select-none leading-none"
        style="color: #1a1030; font-size: 3.5rem;"
      >
        {String(project.id).padStart(2, '0')}
      </span>
    </div>
  )}

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 gap-3">

    <!-- Status + category -->
    <div class="flex items-center justify-between">
      <span class="font-mono-custom text-xs px-2 py-0.5 rounded-full"
            style={`color: ${s.color}; background: ${s.bg};`}>
        {s.label}
      </span>
      <span class="font-mono-custom text-xs" style="color:#7060a0;">{project.clientType}</span>
    </div>

    <!-- Title -->
    <h3 class="serif-display text-lg font-normal text-text leading-snug">{project.title}</h3>

    <!-- Subtitle -->
    <p class="font-mono-custom text-xs" style="color:#149af2;">{project.subtitle}</p>

    <!-- Description -->
    <p class="text-sm text-muted leading-relaxed clamp-3">{project.description}</p>

    <!-- Progress bar (only if < 100) -->
    {project.progress < 100 && (
      <div class="mt-1">
        <div class="flex justify-between mb-1">
          <span class="font-mono-custom text-xs" style="color:#7060a0;">Progreso</span>
          <span class="font-mono-custom text-xs" style="color:#7060a0;">{project.progress}%</span>
        </div>
        <div class="w-full h-0.5 rounded" style="background:#1a1030;">
          <div class="progress-bar rounded" style={`width: ${project.progress}%;`}></div>
        </div>
      </div>
    )}

    <!-- Tech tags -->
    <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
      {project.technologies.slice(0, 5).map(tech => (
        <span class="font-mono-custom text-xs px-2 py-0.5 rounded"
              style="background: rgba(44,4,95,0.4); color:#7060a0; border: 1px solid #1a1030;">
          {tech}
        </span>
      ))}
      {project.technologies.length > 5 && (
        <span class="font-mono-custom text-xs px-2 py-0.5 rounded"
              style="background: rgba(44,4,95,0.4); color:#7060a0; border: 1px solid #1a1030;">
          +{project.technologies.length - 5}
        </span>
      )}
    </div>

    <!-- Links -->
    <div class="flex gap-3 pt-2">
      {hasDemoLink && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium transition-colors duration-200 hover:opacity-70"
          style="color:#149af2;"
        >
          Ver demo →
        </a>
      )}
      {hasGithubLink && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm transition-colors duration-200 hover:text-text"
          style="color:#7060a0; border: 1px solid #1a1030; padding: 1px 10px; border-radius: 6px;"
        >
          GitHub
        </a>
      )}
    </div>

  </div>
</article>

<style>
  .pcard:hover .card-video {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.pcard').forEach(card => {
    const video = card.querySelector<HTMLVideoElement>('.card-video');
    const playBtn = card.querySelector<HTMLButtonElement>('.card-play-btn');
    const playIcon = card.querySelector<HTMLElement>('.card-play-icon');
    if (!video) return;

    // Desktop: hover
    if (window.matchMedia('(pointer: fine)').matches) {
      card.addEventListener('mouseenter', () => { video.play().catch(() => {}); });
      card.addEventListener('mouseleave', () => { video.pause(); video.currentTime = 0; });
    }

    // Mobile: tap play button toggles video
    if (playBtn) {
      let playing = false;
      playBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!playing) {
          video.style.opacity = '1';
          video.play().catch(() => {});
          if (playIcon) {
            playIcon.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
          }
          playing = true;
        } else {
          video.pause();
          video.currentTime = 0;
          video.style.opacity = '0';
          if (playIcon) {
            playIcon.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><polygon points="5,3 19,12 5,21"/></svg>';
          }
          playing = false;
        }
      });
    }
  });
</script>
