---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

const total = projects.length;
// Featured first, then rest
const sorted = [...projects].sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));

const statusTabs = [
  { key: 'all',        label: 'Todos' },
  { key: 'Producción', label: 'Producción' },
  { key: 'Desarrollo', label: 'En desarrollo' },
  { key: 'Demo',       label: 'Demo' },
];
---

<section id="projects" class="py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-10 reveal">
      <p class="font-mono-custom text-xs text-muted uppercase tracking-widest mb-3">// proyectos reales</p>
      <h2 class="serif-display text-3xl md:text-5xl text-text font-normal mb-3">
        {total} proyectos <em class="grad-text not-italic">construidos</em>
      </h2>
      <p id="project-counter" class="font-mono-custom text-xs text-muted">
        Mostrando 6 de {total} proyectos
      </p>
    </div>

    <!-- Status filter tabs -->
    <div class="flex flex-wrap gap-2 mb-8 reveal">
      {statusTabs.map(tab => (
        <button
          class="filter-btn font-mono-custom text-xs px-4 py-1.5 rounded-full transition-all duration-200"
          data-status={tab.key}
          style={tab.key === 'all'
            ? 'background: linear-gradient(135deg, #3d1495, #2a7de5); color:#feffff; border:1px solid transparent;'
            : 'background: transparent; color:#7060a0; border:1px solid #1a1030;'}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Projects grid -->
    <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((project, i) => (
        <div
          class="project-item"
          data-status={project.status}
          data-index={i}
          style={i >= 6 ? 'display:none;' : ''}
        >
          <ProjectCard project={project} />
        </div>
      ))}
    </div>

    <!-- Ver más button -->
    <div id="show-more-wrap" class="flex justify-center mt-10">
      <button
        id="show-more-btn"
        class="font-mono-custom text-xs px-6 py-3 rounded-md transition-all duration-200 hover:opacity-80"
        style="border:1px solid #1a1030; color:#7060a0; background:transparent;"
      >
        Ver todos los proyectos ({total}) ↓
      </button>
    </div>

  </div>
</section>

<script>
  (() => {
    const btns       = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items      = document.querySelectorAll<HTMLElement>('.project-item');
    const counter    = document.getElementById('project-counter');
    const showMoreBtn = document.getElementById('show-more-btn');
    const showMoreWrap = document.getElementById('show-more-wrap');

    const INITIAL_VISIBLE = 6;
    let currentFilter = 'all';
    let expanded = false;

    function getFiltered(): HTMLElement[] {
      return Array.from(items).filter(item =>
        currentFilter === 'all' || item.dataset.status === currentFilter
      );
    }

    function updateCounter(visible: number, total: number) {
      if (counter) {
        counter.textContent = visible === total
          ? `Mostrando todos los ${total} proyectos`
          : `Mostrando ${visible} de ${total} proyectos`;
      }
    }

    function applyFilter() {
      const filtered = getFiltered();
      const total = filtered.length;
      let visible = 0;

      items.forEach(item => {
        item.style.display = 'none';
        item.style.opacity = '0';
      });

      filtered.forEach((item, i) => {
        const show = expanded || i < INITIAL_VISIBLE;
        if (show) {
          item.style.display = 'block';
          // trigger reflow for transition
          item.offsetHeight;
          item.style.transition = 'opacity 0.3s ease';
          item.style.opacity = '1';
          visible++;
        }
      });

      updateCounter(visible, total);

      // Show/hide "Ver más" button
      if (showMoreWrap) {
        showMoreWrap.style.display = (!expanded && total > INITIAL_VISIBLE) ? 'flex' : 'none';
      }
    }

    function setActiveTab(btn: HTMLButtonElement) {
      btns.forEach(b => {
        b.style.background = 'transparent';
        b.style.color = '#7060a0';
        b.style.borderColor = '#1a1030';
      });
      btn.style.background = 'linear-gradient(135deg, #3d1495, #2a7de5)';
      btn.style.color = '#feffff';
      btn.style.borderColor = 'transparent';
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.status ?? 'all';
        expanded = false;
        setActiveTab(btn);
        applyFilter();
      });
    });

    showMoreBtn?.addEventListener('click', () => {
      expanded = true;
      applyFilter();
    });

    // Initial state
    applyFilter();
  })();
</script>
