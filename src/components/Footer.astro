---
const year = new Date().getFullYear();
---
<footer class="footer-glow py-12 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 text-center md:text-left">

      <!-- Left: mini logo + copyright -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <a href="/" class="flex items-center" aria-label="DevCraft inicio">
          <img
            src="/logo.png"
            alt="DevCraft Pablo"
            width="88"
            height="28"
            class="h-7 w-auto object-contain"
            style="filter: drop-shadow(0 0 6px rgba(20,154,242,0.3));"
            loading="lazy"
          />
        </a>
        <p class="font-mono-custom text-xs" style="color:#7060a0;">
          © {year} Pablo Proboste. Todos los derechos reservados.
        </p>
      </div>

      <!-- Center: nav + tagline -->
      <div class="flex flex-col items-center gap-3">
        <nav class="flex flex-wrap justify-center gap-x-4 gap-y-2">
          <a href="#services" class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Servicios</a>
          <a href="#about"    class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Sobre mí</a>
          <a href="#projects" class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Proyectos</a>
          <a href="#process"  class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Proceso</a>
          <a href="#contact"  class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Contacto</a>
        </nav>
        <p class="serif-display italic text-sm" style="color:#7060a0;">Código con propósito.</p>
      </div>

      <!-- Right: stack + location + social -->
      <div class="flex flex-col items-center md:items-end gap-2">
        <p class="font-mono-custom text-xs" style="background: linear-gradient(90deg, #5d038c, #3d1495, #2a7de5, #149af2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Astro · React · Tailwind · Vercel
        </p>
        <div class="flex gap-4">
          <a href="https://instagram.com/probostepablo67" target="_blank" rel="noopener noreferrer"
             aria-label="Instagram de Pablo Proboste (@probostepablo67)"
             class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">Instagram</a>
          <a href="https://linkedin.com/in/pablo-proboste" target="_blank" rel="noopener noreferrer"
             aria-label="LinkedIn de Pablo Proboste"
             class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">LinkedIn</a>
          <a href="https://github.com/31pablo05" target="_blank" rel="noopener noreferrer"
             aria-label="GitHub de Pablo Proboste (31pablo05)"
             class="font-mono-custom text-xs text-muted hover:text-text transition-colors duration-200">GitHub</a>
        </div>
        <p class="font-mono-custom text-xs" style="color:#7060a0;">Trelew, Patagonia 🇦🇷</p>
      </div>

    </div>

  </div>
</footer>

<style>
  .footer-glow {
    position: relative;
  }
  .footer-glow::before {
    content: '';
    position: absolute;
    top: 0; left: 5%; right: 5%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #5d038c 20%, #3d1495 50%, #149af2 80%, transparent);
    box-shadow: 0 0 12px rgba(93,3,140,0.5), 0 0 24px rgba(20,154,242,0.2);
  }
</style>
