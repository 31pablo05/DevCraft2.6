---
export interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}
const {
  title = "Pablo Proboste — DevCraft | Desarrollador Web · Patagonia",
  description = "Portfolio de Pablo Proboste — DevCraft. Desarrollo web con Astro y React, edición de Reels e historias para redes sociales, diseño gráfico y gestión de Instagram/TikTok. 26 proyectos reales. Trelew, Patagonia 🇦🇷",
  canonicalURL = Astro.url.href,
  ogImage = "/og-image.jpg",
} = Astro.props;
---
<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Pablo Proboste" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="AR-U" />
    <meta name="geo.placename" content="Trelew, Chubut, Argentina" />
    <meta name="theme-color" content="#0a0612" />
    <meta name="keywords" content="desarrollador web argentina, desarrollador frontend trelew, react developer argentina, astro developer, tailwind css argentina, pablo proboste, devcraft, portfolio desarrollador web patagonia, programador freelance argentina" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DevCraft — Pablo Proboste" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pablo Proboste — Desarrollador Web Frontend, Patagonia Argentina" />
    <meta property="og:image:secure_url" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@probostepablo67" />
    <meta name="twitter:creator" content="@probostepablo67" />
    <meta name="twitter:title" content="Pablo Proboste — DevCraft | Desarrollador Web" />
    <meta name="twitter:description" content="Desarrollo web, edición de Reels e historias, diseño gráfico y gestión de redes sociales. 26 proyectos reales desde Patagonia 🇦🇷" />
    <meta name="twitter:image" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta name="twitter:url" content={canonicalURL} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <!-- NOTA: Ir a https://search.google.com/search-console -->
    <!-- Agregar la propiedad https://www.devcraft.com.ar y obtener el código real -->
    <!-- Luego reemplazar INSERTAR_CODIGO_REAL_AQUI con ese código -->
    <meta name="google-site-verification" content="WjThKUdjXYUAyd_dIrksu-ggVJkC8iuc_ahZvP5nePs" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/logomejorado.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Global CSS -->
    <style>
      @import "../styles/global.css";
    </style>

    <!-- Force scroll to top on every load -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (window.location.hash) history.replaceState(null, '', window.location.pathname);
      window.scrollTo(0, 0);
    </script>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Pablo Proboste",
          "jobTitle": "Desarrollador Web & Diseñador Digital",
          "url": "https://www.devcraft.com.ar",
          "description": "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 26 proyectos reales. Trelew, Patagonia 🇦🇷",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          },
          "sameAs": [
            "https://linkedin.com/in/pablo-proboste",
            "https://github.com/31pablo05",
            "https://instagram.com/probostepablo67"
          ],
          "image": "https://www.devcraft.com.ar/og-image.jpg",
          "knowsAbout": ["Astro", "React", "Tailwind CSS", "JavaScript", "TypeScript", "Vite", "Vercel", "Node.js"]
        },
        {
          "@type": "WebSite",
          "name": "DevCraft — Pablo Proboste",
          "url": "https://www.devcraft.com.ar",
          "description": "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 26 proyectos reales. Trelew, Patagonia 🇦🇷",
          "inLanguage": "es-AR",
          "potentialAction": {
            "@type": "ReadAction",
            "target": "https://www.devcraft.com.ar"
          }
        },
        {
          "@type": "ProfessionalService",
          "name": "DevCraft — Pablo Proboste",
          "url": "https://www.devcraft.com.ar",
          "description": "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 26 proyectos reales. Trelew, Patagonia 🇦🇷",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          }
        }
      ]
    }
    </script>

    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
        <script set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${import.meta.env.PUBLIC_GA_ID}', { page_path: window.location.pathname });
        `}></script>
      </>
    )}
  </head>
  <body class="bg-bg text-text antialiased">
    <slot />

    <!-- Scroll to top button -->
    <button
      id="scroll-top-btn"
      aria-label="Volver arriba"
      style="
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3d1495, #149af2);
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translateY(12px) scale(0.85);
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
        pointer-events: none;
        box-shadow: 0 4px 20px rgba(61,20,149,0.5), 0 0 0 1px rgba(20,154,242,0.2);
      "
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <script>
      const scrollBtn = document.getElementById('scroll-top-btn');
      if (scrollBtn) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            scrollBtn.style.opacity = '1';
            scrollBtn.style.transform = 'translateY(0) scale(1)';
            scrollBtn.style.pointerEvents = 'auto';
          } else {
            scrollBtn.style.opacity = '0';
            scrollBtn.style.transform = 'translateY(12px) scale(0.85)';
            scrollBtn.style.pointerEvents = 'none';
          }
        }, { passive: true });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
