---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Pablo Proboste — DevCraft | Desarrollador Web · Patagonia",
  description = "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 23 proyectos reales. Trelew, Patagonia 🇦🇷"
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Pablo Proboste" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="AR-U" />
    <meta name="geo.placename" content="Trelew, Chubut, Argentina" />
    <meta name="theme-color" content="#000000" />
    <meta name="keywords" content="desarrollador web argentina, desarrollador frontend trelew, react developer argentina, astro developer, tailwind css argentina, pablo proboste, devcraft, portfolio desarrollador web patagonia, programador freelance argentina" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DevCraft — Pablo Proboste" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://devcraftpablo.online" />
    <meta property="og:image" content="https://devcraftpablo.online/pablo-proboste2.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pablo Proboste — Desarrollador Web Frontend, Patagonia Argentina" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@probostepablo67" />
    <meta name="twitter:creator" content="@probostepablo67" />
    <meta name="twitter:title" content="Pablo Proboste — DevCraft | Desarrollador Web" />
    <meta name="twitter:description" content="Desarrollo web con Astro, React y Tailwind. 23 proyectos reales. Desde Patagonia para el mundo 🇦🇷" />
    <meta name="twitter:image" content="https://devcraftpablo.online/pablo-proboste2.png" />

    <title>{title}</title>
    <link rel="canonical" href="https://devcraftpablo.online" />

    <!-- Preload hero image -->
    <link rel="preload" href="/pablo-proboste2.png" as="image" fetchpriority="high" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Global CSS -->
    <style>
      @import "../styles/global.css";
    </style>

    <!-- Force scroll to top on every load -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (window.location.hash) history.replaceState(null, '', window.location.pathname);
      window.scrollTo(0, 0);
    </script>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Pablo Proboste",
          "jobTitle": "Desarrollador Web Frontend",
          "url": "https://devcraftpablo.online",
          "description": "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 23 proyectos reales. Trelew, Patagonia 🇦🇷",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          },
          "sameAs": [
            "https://linkedin.com/in/pablo-proboste",
            "https://github.com/31pablo05",
            "https://instagram.com/probostepablo67"
          ],
          "knowsAbout": ["Astro", "React", "Tailwind CSS", "JavaScript", "TypeScript", "Vite", "Vercel", "Node.js"]
        },
        {
          "@type": "ProfessionalService",
          "name": "DevCraft — Pablo Proboste",
          "url": "https://devcraftpablo.online",
          "description": "Portfolio profesional de Pablo Proboste (DevCraft). Desarrollo web con Astro, React y Tailwind. 23 proyectos reales. Trelew, Patagonia 🇦🇷",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          }
        }
      ]
    }
    </script>
  </head>
  <body class="bg-bg text-text antialiased">
    <slot />
  </body>
</html>
