---
export interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}
const {
  title = "Pablo Proboste — DevCraft | Desarrollo Web, Diseño Gráfico & Reels · Patagonia Argentina",
  description = "Desarrollador web freelance en Argentina · Pablo Proboste (DevCraft). Sitios web con Astro y React, diseño gráfico, edición de Reels e historias para Instagram y TikTok, gestión de redes sociales y publicidad digital. 26 proyectos reales · Trelew, Patagonia 🇦🇷",
  canonicalURL = `https://www.devcraft.com.ar${Astro.url.pathname}`,
  ogImage = "/og-image.jpg",
} = Astro.props;
---
<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Pablo Proboste" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="AR-U" />
    <meta name="geo.placename" content="Trelew, Chubut, Argentina" />
    <meta name="theme-color" content="#0a0612" />
    <meta name="keywords" content="desarrollador web freelance argentina, desarrollo web trelew patagonia, diseño web argentina, edicion reels instagram argentina, gestion redes sociales argentina, diseño grafico freelance, landing page argentina, sitio web para negocios, pablo proboste devcraft, programador freelance patagonia, creacion de contenido visual, publicidad digital argentina, meta ads google ads argentina" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DevCraft — Pablo Proboste" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pablo Proboste — Desarrollador Web Frontend, Patagonia Argentina" />
    <meta property="og:image:secure_url" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@probostepablo67" />
    <meta name="twitter:creator" content="@probostepablo67" />
    <meta name="twitter:title" content="Pablo Proboste — DevCraft | Desarrollo Web, Diseño & Reels · Patagonia" />
    <meta name="twitter:description" content="Sitios web, diseño gráfico, edición de Reels, gestión de redes sociales y publicidad digital. 26 proyectos reales para negocios reales · Trelew, Argentina 🇦🇷" />
    <meta name="twitter:image" content={`https://www.devcraft.com.ar${ogImage}`} />
    <meta name="twitter:url" content={canonicalURL} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="google-site-verification" content="WjThKUdjXYUAyd_dIrksu-ggVJkC8iuc_ahZvP5nePs" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/logomejorado.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Global CSS -->
    <style>
      @import "../styles/global.css";
    </style>

    <!-- Force scroll to top on every load -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (window.location.hash) history.replaceState(null, '', window.location.pathname);
      window.scrollTo(0, 0);
    </script>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Pablo Proboste",
          "jobTitle": "Desarrollador Web & Diseñador Digital",
          "url": "https://www.devcraft.com.ar",
          "description": "Desarrollador web freelance y creador de contenido digital. Desarrollo sitios web con Astro, React y Tailwind, edición de Reels para Instagram y TikTok, diseño gráfico, gestión de redes sociales y publicidad en Meta Ads y Google Ads. 26 proyectos reales desde Trelew, Patagonia.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          },
          "sameAs": [
            "https://linkedin.com/in/pablo-proboste",
            "https://github.com/31pablo05",
            "https://instagram.com/probostepablo67"
          ],
          "image": "https://www.devcraft.com.ar/og-image.jpg",
          "knowsAbout": ["Astro", "React", "Tailwind CSS", "JavaScript", "TypeScript", "Vite", "Vercel", "Node.js", "Canva Pro", "Edición de Video", "Reels Instagram", "Diseño Gráfico", "Gestión de Redes Sociales", "Meta Ads", "Google Ads"]
        },
        {
          "@type": "WebSite",
          "name": "DevCraft — Pablo Proboste",
          "url": "https://www.devcraft.com.ar",
          "description": "Desarrollador web freelance, diseñador gráfico y creador de contenido digital en Argentina. Sitios web, Reels, diseño y gestión de redes sociales para negocios reales.",
          "inLanguage": "es-AR",
          "potentialAction": {
            "@type": "ReadAction",
            "target": "https://www.devcraft.com.ar"
          }
        },
        {
          "@type": "ProfessionalService",
          "name": "DevCraft — Pablo Proboste",
          "url": "https://www.devcraft.com.ar",
          "description": "Servicio de desarrollo web, diseño gráfico, edición de Reels e historias, gestión de redes sociales y publicidad digital. Freelance disponible para proyectos en Argentina y Latinoamérica.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Trelew",
            "addressRegion": "Chubut",
            "addressCountry": "AR"
          },
          "areaServed": ["Argentina", "Latinoamérica"],
          "serviceType": [
            "Desarrollo Web",
            "Landing Pages",
            "Sitios Institucionales",
            "E-commerce",
            "Diseño Gráfico",
            "Edición de Reels",
            "Edición de Historias Instagram",
            "Gestión de Redes Sociales",
            "Community Manager",
            "Publicidad Digital",
            "Meta Ads",
            "Google Ads"
          ],
          "priceRange": "$$",
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Servicios Digitales",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sitios Web Premium" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Contenido Visual y Diseño Gráfico" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gestión de Redes Sociales" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Publicidad Digital Meta Ads y Google Ads" } }
            ]
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Cuánto cuesta hacer un sitio web profesional en Argentina?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El costo varía según el alcance: una landing page arranca desde precios accesibles, y proyectos más complejos como e-commerce o aplicaciones web tienen mayor inversión. Contactame para una cotización gratuita y personalizada."
              }
            },
            {
              "@type": "Question",
              "name": "¿Hacés edición de Reels e historias para Instagram?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sí, ofrezco edición profesional de Reels e historias para Instagram y TikTok, diseño de piezas gráficas y gestión completa de redes sociales para marcas y negocios."
              }
            },
            {
              "@type": "Question",
              "name": "¿Trabajás de forma remota para toda Argentina?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sí, trabajo 100% remoto desde Trelew, Patagonia, para clientes en todo el país y Latinoamérica. El proceso completo de diseño, desarrollo y entrega se realiza de manera online."
              }
            },
            {
              "@type": "Question",
              "name": "¿Qué servicios digitales ofrecés?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ofrezco desarrollo web (landing pages, sitios institucionales, e-commerce), diseño gráfico y contenido visual, edición de Reels e historias, gestión de redes sociales (Instagram, TikTok) y publicidad digital (Meta Ads, Google Ads)."
              }
            }
          ]
        }
      ]
    }
    </script>

    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
        <script set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${import.meta.env.PUBLIC_GA_ID}', { page_path: window.location.pathname });
        `}></script>
      </>
    )}
  </head>
  <body class="bg-bg text-text antialiased">
    <slot />

    <!-- Scroll to top button -->
    <button
      id="scroll-top-btn"
      aria-label="Volver arriba"
      style="
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3d1495, #149af2);
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translateY(12px) scale(0.85);
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
        pointer-events: none;
        box-shadow: 0 4px 20px rgba(61,20,149,0.5), 0 0 0 1px rgba(20,154,242,0.2);
      "
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <script>
      const scrollBtn = document.getElementById('scroll-top-btn');
      if (scrollBtn) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            scrollBtn.style.opacity = '1';
            scrollBtn.style.transform = 'translateY(0) scale(1)';
            scrollBtn.style.pointerEvents = 'auto';
          } else {
            scrollBtn.style.opacity = '0';
            scrollBtn.style.transform = 'translateY(12px) scale(0.85)';
            scrollBtn.style.pointerEvents = 'none';
          }
        }, { passive: true });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
